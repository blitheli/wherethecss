# 环境变量示例文件
# 复制此文件为 .env 并填入你的真实 API Key

# Google Maps Platform API Key
# 申请地址: https://console.cloud.google.com/
# 需要启用 Map Tiles API
STORYBOOK_GOOGLE_MAP_API_KEY=your_api_key_here

# Cesium Ion API Token (可选)
# 申请地址: https://ion.cesium.com/
# 默认使用公共示例 token，如需使用自己的数据集请申请
# VITE_CESIUM_ION_TOKEN=your_cesium_token_here
